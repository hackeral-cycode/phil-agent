{
  "mcpServers": {
    "cycode": {
      "command": "/opt/homebrew/bin/cycode",
      "args": ["mcp"]
    },
    "atlassian": {
      "command": "uvx",
      "args": ["mcp-atlassian"],
      "env": {
        "CONFLUENCE_URL": "https://YOUR_ORG.atlassian.net/wiki",
        "CONFLUENCE_USERNAME": "your.email@yourcompany.com",
        "CONFLUENCE_API_TOKEN": "YOUR_ATLASSIAN_API_TOKEN",
        "JIRA_URL": "https://YOUR_ORG.atlassian.net",
        "JIRA_USERNAME": "your.email@yourcompany.com",
        "JIRA_API_TOKEN": "YOUR_ATLASSIAN_API_TOKEN"
      }
    }
  }
}
